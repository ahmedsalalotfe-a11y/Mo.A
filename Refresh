<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>تطبيق الـ 1000 سؤال الذكي</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f0f2f5;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }
    .quiz-container {
      background-color: white;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      width: 90%;
      max-width: 500px;
      text-align: center;
    }
    h2 {
      color: #333;
      margin-bottom: 20px;
      font-size: 22px;
      line-height: 1.4;
    }
    .options-container {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 20px;
    }
    button {
      background-color: #e4e6eb;
      color: #050505;
      border: none;
      padding: 12px;
      border-radius: 8px;
      font-size: 16px;
      cursor: pointer;
      transition: background-color 0.2s;
    }
    button:hover {
      background-color: #d8dadf;
    }
    button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
    .category-btn {
      background-color: #007bff;
      color: white;
      font-weight: bold;
    }
    .category-btn:hover {
      background-color: #0056b3;
    }
    .result {
      font-size: 18px;
      font-weight: bold;
      margin-top: 15px;
    }
    .hidden {
      display: none !important;
    }
    .loading-text {
      color: #007bff;
      font-style: italic;
      font-weight: bold;
    }
  </style>
</head>
<body>

<div class="quiz-container">
  <div id="category-screen">
    <h2>اختر مجالك المفضل (أسئلة عربية لا تنتهي):</h2>
    <div class="options-container">
      <button class="category-btn" onclick="fetchQuestions(21)">⚽ رياضة</button>
      <button class="category-btn" onclick="fetchQuestions(17)">🔬 علوم وطبيعة</button>
      <button class="category-btn" onclick="fetchQuestions(23)">📜 تاريخ</button>
      <button class="category-btn" onclick="fetchQuestions(9)">🌍 معلومات عامة</button>
    </div>
  </div>

  <div id="quiz-screen" class="hidden">
    <h2 id="question" class="loading-text">جاري جلب الأسئلة عبر الإنترنت...</h2>
    <div class="options-container" id="options"></div>
    <div class="result" id="feedback"></div>
  </div>
</div>

<script>
  let activeQuestions = [];
  let currentQuestionIndex = 0;
  let score = 0;

  const categoryScreen = document.getElementById("category-screen");
  const quizScreen = document.getElementById("quiz-screen");
  const questionElement = document.getElementById("question");
  const optionsContainer = document.getElementById("options");
  const feedbackElement = document.getElementById("feedback");

  async function translateToArabic(text) {
    try {
      const response = await fetch(`https://api.mymemory.translated.net/get?q=${encodeURIComponent(text)}&langpair=en|ar`);
      const data = await response.json();
      return data.responseData.translatedText || text;
    } catch (error) {
      return text; 
    }
  }

  async function fetchQuestions(categoryId) {
    categoryScreen.classList.add("hidden");
    quizScreen.classList.remove("hidden");
    questionElement.textContent = "جاري الاتصال ببنك الأسئلة العالمي وسحب الأسئلة...";
    questionElement.className = "loading-text";
    optionsContainer.innerHTML = "";
    feedbackElement.textContent = "";

    try {
      const response = await fetch(`https://opentdb.com/api.php?amount=10&category=${categoryId}&type=multiple`);
      const data = await response.json();
      
      if (data.results && data.results.length > 0) {
        activeQuestions = data.results;
        currentQuestionIndex = 0;
        score = 0;
        loadQuestion();
      } else {
        questionElement.textContent = "عذراً، حدث خطأ أثناء جلب الأسئلة. حاول مجدداً.";
      }
    } catch (error) {
      questionElement.textContent = "يرجى التحقق من اتصالك بالإنترنت والمحاولة مرة أخرى.";
    }
  }

  function shuffleArray(array) {
    for (let i = array.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [array[i], array[j]] = [array[j], array[i]];
    }
    return array;
  }

  function decodeHTML(html) {
    const txt = document.createElement("textarea");
    txt.innerHTML = html;
    return txt.value;
  }

  async function loadQuestion() {
    feedbackElement.textContent = "";
    optionsContainer.innerHTML = "";

    if (currentQuestionIndex < activeQuestions.length) {
      questionElement.textContent = "جاري ترجمة السؤال والخيارات إلى العربية... ⏳";
      questionElement.className = "loading-text";

      let rawQuestionObj = activeQuestions[currentQuestionIndex];
      
      let englishQuestion = decodeHTML(rawQuestionObj.question);
      let englishCorrectAnswer = decodeHTML(rawQuestionObj.correct_answer);
      let englishIncorrectAnswers = rawQuestionObj.incorrect_answers.map(decodeHTML);

      const translationPromises = [
        translateToArabic(englishQuestion),
        translateToArabic(englishCorrectAnswer),
        ...englishIncorrectAnswers.map(ans => translateToArabic(ans))
      ];

      const [translatedQuestion, translatedCorrectAnswer, ...translatedIncorrectAnswers] = await Promise.all(translationPromises);

      questionElement.textContent = translatedQuestion;
      questionElement.className = ""; 

      let allOptions = [...translatedIncorrectAnswers, translatedCorrectAnswer];
      let shuffledOptions = shuffleArray(allOptions);

      shuffledOptions.forEach(option => {
        const button = document.createElement("button");
        button.textContent = option;
        button.onclick = () => checkAnswer(option, translatedCorrectAnswer);
        optionsContainer.appendChild(button);
      });
    } else {
      questionElement.textContent = `انتهت الجولة! 🎉`;
      optionsContainer.innerHTML = `<button class="category-btn" onclick="goHome()">العب جولة جديدة بأسئلة أخرى</button>`;
      feedbackElement.textContent = `درجتك النهائية هي: ${score} من ${activeQuestions.length}`;
      feedbackElement.style.color = "#007bff";
    }
  }

  function checkAnswer(userAnswer, correctAnswer) {
    const buttons = optionsContainer.querySelectorAll("button");
    buttons.forEach(btn => btn.disabled = true);

    if (userAnswer === correctAnswer) {
      score++;
      feedbackElement.textContent = "إجابة صحيحة! 🎉";
      feedbackElement.style.color = "green";
    } else {
      feedbackElement.textContent = `إجابة خاطئة ❌ الصحيح هو: ${correctAnswer}`;
      feedbackElement.style.color = "red";
    }

    setTimeout(() => {
      currentQuestionIndex++;
      loadQuestion();
    }, 2000);
  }

  function goHome() {
    quizScreen.classList.add("hidden");
    categoryScreen.classList.remove("hidden");
  }
</script>

</body>
</html>
